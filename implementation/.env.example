# NODE_ENV=development | production
NODE_ENV=production

# API
API_PORT=3000

# Database (Postgres - applications, users, tests)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=monitor
DB_PASSWORD=change_me
DB_DATABASE=monitoring

# TimescaleDB (metrics storage)
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5433

# Redis (BullMQ queues, caching)
REDIS_HOST=redis
REDIS_PORT=6379

# Auth
JWT_SECRET=change_me_jwt_secret
JWT_EXPIRES_IN=7d

# Loki (log aggregation)
LOKI_HOST=http://loki:3100

# Domains (replace with your actual domains)
DOMAIN=app.example.com
GRAFANA_DOMAIN=grafana.example.com

# CORS (comma-separated origins allowed, or * for all)
CORS_ORIGIN=https://app.example.com

# Postgres credentials (used by Docker containers directly)
POSTGRES_USER=monitor
POSTGRES_PASSWORD=change_me
POSTGRES_DB=monitoring
