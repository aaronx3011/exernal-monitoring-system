# API URL (used by the dashboard to make API calls)
# In production behind nginx, this defaults to /api/v1 (same origin)
# Set explicitly if the API is on a different domain
# VITE_API_URL=https://app.example.com/api/v1

# Grafana URL for embedding dashboards
VITE_GRAFANA_URL=https://grafana.example.com

# Vite proxy target (used in dev mode only)
# VITE_API_PROXY_TARGET=http://localhost:3000
